# Copy to `.env` and fill in. The suite reads these three values.
# BASE_URL must include the /v1 suffix (OpenAI-compatible base).
BASE_URL=https://YOUR-HOST.jarvislabs.net/v1
# API key the vLLM server was launched with. If the server has no auth,
# leave blank or set EMPTY — the suite falls back to "EMPTY" and E5 becomes N/A.
API_KEY=
# The served model name (what you pass as `model` in requests).
MODEL=qwen
