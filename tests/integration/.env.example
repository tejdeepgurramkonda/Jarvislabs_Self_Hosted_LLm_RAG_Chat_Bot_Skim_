# Copy to `.env` and adjust. Most values fall back to rag-backend/.env, so usually
# you only need BACKEND_URL here.
BACKEND_URL=http://localhost:8090
FRONTEND_ORIGIN=http://localhost:5173

# Optional — only used by the bad-key seam test (S1.3). If omitted, reused from
# rag-backend/.env (LLM_BASE_URL / LLM_API_KEY), then tests/vllm/.env.
# VLLM_BASE_URL=https://<host>.notebooksn.jarvislabs.net/v1
# VLLM_API_KEY=<your vllm key>
